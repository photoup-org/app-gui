generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PlanTier {
  id                       String  @id @default(cuid())
  name                     String
  includedGateways         Int     @default(1)
  includedSensors          Int
  maxSensors               Int?
  extraSensorStripePriceId String?

  // --- BACKEND LIMITS (Strict Logic) ---
  maxUsers            Int? // Limit team members (e.g., 3 or null for unlimited)
  dataRetentionMonths Int  @default(6) // e.g., 6, 12, 84

  // --- UI MATRIX (Flexible Rendering) ---
  uiFeatureMatrix Json? // Stores the categorized feature list for the UI table

  priceAmount     Int          @default(0)
  currency        String       @default("eur")
  marketingDesc   String?
  isPopular       Boolean      @default(false)
  orderIndex      Int          @default(0)
  stripeProductId String       @unique @default(cuid())
  departments     Department[]
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  nif         String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  departments Department[]
}

model Department {
  id                   String             @id @default(uuid())
  slug                 String             @unique
  name                 String
  auth0OrgId           String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  planId               String?
  subStatus            SubscriptionStatus @default(ACTIVE)
  organizationId       String
  billingAddressId     String
  shippingAddressId    String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  billingAddress       Address            @relation("BillingAddress", fields: [billingAddressId], references: [id])
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan                 PlanTier?          @relation(fields: [planId], references: [id])
  shippingAddress      Address?           @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  labProfile           LabProfile? // Null means they haven't picked yet
  devices              Device[]
  orders               Order[]
  users                User[]
  projects             Project[]
  alerts               Alert[]
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  auth0UserId  String?    @unique
  role         Role       @default(VIEWER)
  jobTitle     String?
  phone        String?
  departmentId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  orders       Order[]
}

model Address {
  id                  String       @id @default(cuid())
  street              String
  city                String
  zipCode             String
  country             String
  nif                 String?
  contactName         String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  billingDepartments  Department[] @relation("BillingAddress")
  shippingDepartments Department[] @relation("ShippingAddress")
}

model HardwareProduct {
  id              String       @id @default(cuid())
  sku             String       @unique
  name            String
  subtitle        String
  description     String?
  imageUrl        String?
  stripeProductId String?      @unique
  type            HardwareType
  stockQuantity   Int          @default(0)
  price           Decimal      @db.Decimal(10, 2)
  isFeatured      Boolean      @default(false) // <-- ADD THIS LINE
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  devices         Device[]
  orderItems      OrderItem[]
}

model Device {
  id           String              @id @default(cuid())
  serialNumber String              @unique
  status       DeviceStatus        @default(ACTIVE)
  productId    String
  departmentId String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  department   Department          @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  product      HardwareProduct     @relation(fields: [productId], references: [id])
  readings     SensorReading[]
  experimentId String?
  experiment   Experiment?         @relation(fields: [experimentId], references: [id], onDelete: SetNull)
  calibrations CalibrationRecord[]
  alerts       Alert[]
}

model Order {
  id             String      @id @default(cuid())
  status         OrderStatus @default(PENDING_PAYMENT)
  departmentId   String
  customerEmail  String?
  customerName   String?
  userId         String?
  stripeIntentId String?     @unique
  trackingNumber String?
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  department     Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  items          OrderItem[]
}

model OrderItem {
  id        String          @id @default(cuid())
  quantity  Int
  orderId   String
  productId String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   HardwareProduct @relation(fields: [productId], references: [id])
}

model SensorReading {
  id           String      @id @default(cuid())
  deviceId     String
  metricType   String
  value        Float
  timestamp    DateTime    @default(now())
  device       Device      @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  experimentId String?
  experiment   Experiment? @relation(fields: [experimentId], references: [id], onDelete: SetNull)

  // Update your index to make experiment data retrieval fast
  @@index([deviceId, timestamp(sort: Desc)])
  @@index([experimentId, timestamp(sort: Desc)]) // NEW INDEX
}

model CalibrationRecord {
  id           String   @id @default(cuid())
  deviceId     String
  calibratedAt DateTime @default(now())
  validUntil   DateTime
  performedBy  String // e.g., "Fábrica", "Operador X"
  notes        String?

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, calibratedAt(sort: Desc)])
}

model Alert {
  id           String        @id @default(cuid())
  departmentId String
  deviceId     String?
  experimentId String? // <-- ADDED: Link directly to the experiment
  severity     AlertSeverity
  title        String
  message      String?
  isRead       Boolean       @default(false)
  createdAt    DateTime      @default(now())

  department Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  device     Device?     @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  experiment Experiment? @relation(fields: [experimentId], references: [id], onDelete: SetNull)

  @@index([departmentId, createdAt(sort: Desc)])
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID_UNSHIPPED
  SHIPPED
  CANCELED
}

enum Role {
  ADMIN
  OPERATOR
  SUPER_ADMIN
  VIEWER
}

enum HardwareType {
  GATEWAY
  SENSOR_BASE
  SENSOR_PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
}

enum DeviceStatus {
  UNCLAIMED
  BUSY
  ACTIVE
  OFFLINE
  MAINTENANCE
}

enum LabProfile {
  CONTINUOUS
  PROJECTS
}

model PendingCart {
  id        String   @id @default(cuid())
  items     Json // Store the raw cart items array here
  createdAt DateTime @default(now())
}

// --- NEW ENUMS ---
enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum ExperimentStatus {
  PLANNED
  RUNNING
  COMPLETED
  PAUSED
}

model Project {
  id           String        @id @default(cuid())
  name         String
  description  String?
  departmentId String
  status       ProjectStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  department  Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  experiments Experiment[]
}

model Experiment {
  id        String           @id @default(cuid())
  name      String
  projectId String
  status    ExperimentStatus @default(RUNNING)
  startDate DateTime         @default(now())
  endDate   DateTime?
  settings  Json?
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  devices   Device[]
  alerts    Alert[]
  readings  SensorReading[]
}
