            {/* Cargo */}
            <div className="space-y-1.5">
                <Label htmlFor="jobTitle">
                    Cargo<span className="text-destructive ml-0.5">*</span>
                </Label>
                <Input
                    id="jobTitle"
                    placeholder="Engenheiro de Software"
                    {...register('jobTitle', { required: 'Cargo é obrigatório' })}
